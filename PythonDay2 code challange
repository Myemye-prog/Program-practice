# 18. Count vowels in a string.
msg="Are you okay"
count=0
for i in msg:
    if i in "aeiouAEIOU":
        count+=1
print(f"Total owels in this '{msg}' string is {count}")
# 19. Count consonants in a string.
msg="Are you okay"
count=0
for i in msg:
    if i not in "aeiouAEIOU" and i !=" ":
        count+=1
print(f"Total consonants in this '{msg}' string is {count}")
