# 13. Calculate the sum of even numbers from 1 to 50.
i=1
sum=0
for i in range(51):
    if i%2==0:
        sum=sum+i
print(f"Sum of all even numbers from 1 to 50 is {sum}")
# 14. Calculate the sum of odd numbers from 1 to 50.
i=1
sum=0
for i in range(51):
    if i%2!=0:
        sum=sum+i
print(f"Sum of all odd numbers from 1 to 50 is {sum}")
