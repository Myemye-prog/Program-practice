# 16. Print characters of a string.
string = "You are the only one for her if you think like this fuck your thinking"
length = len(string)
i = 0

while i < length:
    print(string[i], end="-")
    i += 1

print()

# 17. Count vowels.
count = 0
i = 0

while i < length:
    if string[i] in "aeiouAEIOU":
        count += 1
    i += 1

print(f"Total vowels in the string is {count}")

# 18. Count consonants.
count = 0
i = 0

while i < length:
    if string[i] not in "aeiouAEIOU" and string[i] != " ":
        count += 1
    i += 1

print(f"Total consonants in the string is {count}")

# 19. Count spaces.
count = 0
i = 0

while i < length:
    if string[i] == " ":
        count += 1
    i += 1

print(f"Total spaces in the string is {count}")

# 20. Reverse a string.
i = len(string) - 1

while i >= 0:
    print(string[i], end="")
    i -= 1

print()
