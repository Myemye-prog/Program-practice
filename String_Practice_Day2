# 17. Count occurrences of a character.
string = "You are the only one for her if you think like this,Then fuck your thinking"

freq = {}

for ch in string:
    freq[ch] = freq.get(ch, 0) + 1

for ch, count in freq.items():
    print(f"'{ch}' occurs {count} times")

